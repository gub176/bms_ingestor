{
    "permissions": {
		"allow": [
		  "Read", "Write", "Edit",      // 自动批准文件操作
		  "Bash(npm run *)",            // 允许所有 npm run 命令
		  "Bash(git status)", 
		  "Bash(git diff)",
		  "WebSearch",
		  "WebFetch(domain:github.com)"
		],
		"deny": [
		  "Bash(rm -rf)",               // 永远拦截高危命令
		  "Bash(sudo *)"
		]
	}
}
